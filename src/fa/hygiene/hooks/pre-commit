#!/usr/bin/env bash
# pre-commit — run the configured pre-commit hooks via the project environment.
#
# This script replaces the standard ``pre-commit install`` hook.  The
# framework's generated hook locates ``pre-commit`` via PATH, which
# fails in uv-managed environments on Windows (where the executable
# lives inside ``.venv/Scripts/`` and is not on the system PATH).
# Invoking through ``uv run`` ensures the project environment is
# always used regardless of the shell's PATH configuration.
#
# ``pre-commit run`` with no arguments automatically checks only
# staged files — the correct behaviour for a pre-commit hook.
#
# Proxy bypass: pre-commit builds isolated Python virtualenvs and
# runs ``pip install`` inside them.  On Windows, pip reads the
# system proxy from the registry (Internet Settings), even when
# no proxy env vars are set.  If the system proxy is SOCKS-based,
# pip fails with "Missing dependencies for SOCKS support" because
# the isolated env doesn't have PySocks.  Setting ``NO_PROXY=*``
# here tells urllib/requests/pip to bypass all proxies, regardless
# of what the registry says.  This only affects the git hook
# execution path — nothing else on the system.
#
# Auto-retry: if a hook modifies files (trailing-whitespace,
# end-of-file-fixer, ruff --fix), those changes are left in the
# working tree but NOT re-staged, and the commit fails with exit 1.
# This requires the contributor to manually ``git add -u`` and
# re-commit — friction that defeats the purpose of autofix hooks.
# Instead, we detect that hooks made changes, re-stage them, and
# retry once.  If the retry passes, the commit proceeds.  If it
# still fails, the commit is blocked as expected (real error, not
# just an unstaged fix).

set -euo pipefail

# Bypass system SOCKS/HTTP proxy for pip inside pre-commit envs.
# Only affects this hook process and its children — does not
# change system or VS Code proxy settings.
export NO_PROXY="*"

uv run pre-commit run "$@"
rc=$?

if [ $rc -ne 0 ]; then
    # Check whether hooks modified (but did not stage) any files.
    changed=$(git diff --name-only --diff-filter=M 2>/dev/null || true)
    if [ -n "$changed" ]; then
        echo "pre-commit: re-staging auto-fixed files and retrying:" >&2
        echo "$changed" | sed 's/^/  /' >&2
        git add -u
        uv run pre-commit run "$@"
        rc=$?
    fi
fi

exit $rc
