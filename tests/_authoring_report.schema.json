{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FA Authoring KernelReport",
  "description": "Test asset. The kernel does not self-validate against this schema; the schema is enforced by tests/test_authoring_report_schema.py to catch silent shape additions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kernel_version",
    "kernel_hash",
    "snapshot_id",
    "rule_pack_hash",
    "allowlist_signature",
    "dispatched_count",
    "session_hash",
    "diagnostics",
    "exit_code"
  ],
  "properties": {
    "kernel_version": { "type": "string" },
    "kernel_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "snapshot_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "rule_pack_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "allowlist_signature": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "dispatched_count": { "type": "integer", "minimum": 0 },
    "session_hash": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      ]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "path", "message", "remediation", "rule_input_hash"],
        "properties": {
          "severity": { "type": "string", "enum": ["HARD-BLOCK", "ADVISORY", "INFO"] },
          "code": { "type": "string", "pattern": "^FA-AUTHORING-V[0-9]+-[A-Z0-9-]+$" },
          "path": { "type": "string" },
          "line": {
            "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }]
          },
          "column": {
            "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }]
          },
          "message": { "type": "string" },
          "remediation": { "type": "string" },
          "rule_input_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "expires_on": {
            "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }]
          }
        }
      }
    },
    "exit_code": { "type": "integer", "enum": [0, 1] }
  }
}
