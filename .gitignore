.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
__pycache__/
*.egg-info/
dist/
build/
.fa/
.devin/

# Environment files (may contain secrets like B2 credentials)
.env*
!.env.example
!.env.fa.template

# Explicit secret markers (already covered by .env* above, but explicit for operators)
.env.fa

# Secret material directory (ADR-12). Block everything except templates so a
# real fa.env / proxy token can never be committed.
secrets/*
!secrets/*.template

# Prevent accidental copies of FA config files into repo
models.yaml
config.yaml

# OS metadata
.DS_Store
Thumbs.db

# Log files
*.log

# Coverage / mutation artifacts
.coverage
coverage.xml
# mutmut 3.x writes a full mutated source tree at repo root during `just mutation`
mutants/
htmlcov/
.mutmut-cache
.gremlins-cache/
gremlin-report.html
# Session trace artifacts (written by LearningObserver and agent sessions).
# Ignore all agent-generated files; keep only the three tracked seed files
# (codebase_map.json, exploration_log.md, exploration_tree.yaml).
# Use `fa commit-traces` to commit trace updates on operator demand.
knowledge/trace/*
!knowledge/trace/codebase_map.json
!knowledge/trace/exploration_log.md
!knowledge/trace/exploration_tree.yaml
