#!/usr/bin/env bash
# scripts/fa — unified FA operator interface (host-side).
#
# Two layers behind one command:
#   1. Infrastructure verbs (logs, restart, up, down, rebuild, status, shell)
#      run on the HOST via docker compose — closed set, docker compose API.
#   2. Everything else delegates to `fa` CLI INSIDE the agent container
#      (selfcheck, probe, run, chunk, authoring-check, --version, …).
#      New Python subcommands work automatically — no wrapper change needed.
#
# Install:  sudo ln -sf /srv/first-agent/repo/First-Agent-dev/scripts/fa /usr/local/bin/fa
# Override: FA_COMPOSE_FILE=docker-compose.custom.yml fa status

set -euo pipefail

# Resolve symlink: when installed as /usr/local/bin/fa → scripts/fa,
# $0 is the symlink path, not the target. readlink -f follows the chain.
_SELF="$(readlink -f "$0")"
REPO_DIR="$(cd "$(dirname "$_SELF")/.." && pwd)"
COMPOSE_FILE="${FA_COMPOSE_FILE:-docker-compose.fa.yml}"
COMPOSE="docker compose -f $REPO_DIR/$COMPOSE_FILE"

# TTY detection: pass -T (disable TTY) when stdin is not a terminal
# (pipes, scripts, cron). Keep TTY for interactive use (fa shell).
TTY_FLAG="-T"
if [ -t 0 ] && [ -t 1 ]; then
    TTY_FLAG=""
fi

# Resolve active session workspace for docker exec commands
_SESSION_WORKSPACE=""
_FA_ROOT="$(dirname "$(dirname "$REPO_DIR")")"
if [[ -f "$_FA_ROOT/sessions/.active" ]]; then
    _SESSION_WORKSPACE="$(cat "$_FA_ROOT/sessions/.active")"
fi

_W_FLAG=""
if [[ -n "$_SESSION_WORKSPACE" ]]; then
    _W_FLAG="-w $_SESSION_WORKSPACE"
fi

_is_help_arg() {
    case "${1:-}" in
        -h|--help|-help|help) return 0 ;;
        *) return 1 ;;
    esac
}

_help_python() {
    PYTHONPATH="$REPO_DIR/src${PYTHONPATH:+:$PYTHONPATH}" "${PYTHON:-python3}" -m fa.cli_help "$@"
}

_print_usage() {
    _help_python --wrapper-usage
}

_print_host_topic_help() {
    _help_python --host-topic "${1:-}"
}
_delegate_to_agent() {
    if [[ -n "$_W_FLAG" ]]; then
        exec $COMPOSE exec $TTY_FLAG -w "$_SESSION_WORKSPACE" first-agent fa "$@"
    else
        exec $COMPOSE exec $TTY_FLAG first-agent fa "$@"
    fi
}

_delegate_agent_help() {
    local topic="$1"
    shift || true
    if [[ "$topic" == "help" ]]; then
        _delegate_to_agent help "$@"
    else
        _delegate_to_agent "$topic" "$@"
    fi
}

case "${1:-}" in
    # ── Infrastructure verbs (host-side, docker compose level) ──────────
    logs)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help logs; exit 0; fi
        exec $COMPOSE logs "$@" first-agent
        ;;
    proxy-logs)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help proxy-logs; exit 0; fi
        exec $COMPOSE logs "$@" fa-egress-proxy
        ;;
    status)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help status; exit 0; fi
        exec $COMPOSE ps
        ;;
    up)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help up; exit 0; fi
        exec $COMPOSE up -d
        ;;
    down)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help down; exit 0; fi
        exec $COMPOSE down
        ;;
    restart)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help restart; exit 0; fi
        exec $COMPOSE restart first-agent fa-egress-proxy
        ;;
    rebuild)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help rebuild; exit 0; fi
        exec $COMPOSE up -d --build
        ;;
    shell)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help shell; exit 0; fi
        if [[ -n "$_W_FLAG" ]]; then
            exec $COMPOSE exec -w "$_SESSION_WORKSPACE" first-agent bash "$@"
        else
            exec $COMPOSE exec first-agent bash "$@"
        fi
        ;;
    update)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help update; exit 0; fi
        exec "$REPO_DIR/scripts/fa-update.sh" "$@"
        ;;
    clean-rebuild)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help clean-rebuild; exit 0; fi
        exec "$REPO_DIR/scripts/fa-clean-rebuild.sh" "$@"
        ;;
    clean)
        if [[ "${2:-}" == "rebuild" || "${2:-}" == "clean-rebuild" ]]; then
            echo "fa: use 'fa clean-rebuild' (hyphen), not 'fa clean rebuild'" >&2
            exit 2
        fi
        _delegate_to_agent "$@"
        ;;
    commit-traces)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help commit-traces; exit 0; fi
        cd "$REPO_DIR"
        # -f: force-add gitignored trace files (they're ignored by default
        # so fa-update.sh stays clean; commit-traces is the deliberate path).
        git add -f knowledge/trace/codebase_map.json knowledge/trace/gotchas.md 2>/dev/null
        git diff --cached --quiet && { echo "fa: no trace changes to commit"; exit 0; }
        git commit -m "chore: update session trace artifacts"
        echo "fa: trace artifacts committed"
        exit 0
        ;;
    sessions)
        shift
        if _is_help_arg "${1:-}"; then _print_host_topic_help sessions; exit 0; fi
        ls -lt "$_FA_ROOT/sessions/" | grep -v "^total\|\.active"
        ;;

    # ── Help ────────────────────────────────────────────────────────────
    ""|--help|-h|-help)
        if [[ $# -ge 2 ]] && _print_host_topic_help "$2"; then
            exit 0
        fi
        if [[ $# -ge 2 ]]; then
            # Agent command global form: `fa --help run` / `fa -h run`.
            _delegate_agent_help "$2" --help "${@:3}"
        fi
        _print_usage
        exit 0
        ;;
    help)
        shift
        if [[ $# -eq 0 ]]; then
            _print_usage
            exit 0
        fi
        if _print_host_topic_help "$1"; then
            exit 0
        fi
        _delegate_to_agent help "$@"
        ;;

    # ── Default: delegate to fa CLI inside the agent container ──────────
    *)
        if [[ "${2:-}" == "-help" ]]; then
            # Compatibility for operators who type `fa run -help`.
            set -- "$1" --help "${@:3}"
        fi
        _delegate_to_agent "$@"
        ;;
esac
