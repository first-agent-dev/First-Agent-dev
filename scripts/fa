#!/usr/bin/env bash
# scripts/fa — unified FA operator interface (host-side).
#
# Two layers behind one command:
#   1. Infrastructure verbs (logs, restart, up, down, rebuild, status, shell)
#      run on the HOST via docker compose — closed set, docker compose API.
#   2. Everything else delegates to `fa` CLI INSIDE the agent container
#      (selfcheck, probe, run, chunk, authoring-check, --version, …).
#      New Python subcommands work automatically — no wrapper change needed.
#
# Install:  sudo ln -sf /srv/first-agent/repo/First-Agent-dev/scripts/fa /usr/local/bin/fa
# Override: FA_COMPOSE_FILE=docker-compose.custom.yml fa status

set -euo pipefail

# Resolve symlink: when installed as /usr/local/bin/fa → scripts/fa,
# $0 is the symlink path, not the target. readlink -f follows the chain.
_SELF="$(readlink -f "$0")"
REPO_DIR="$(cd "$(dirname "$_SELF")/.." && pwd)"
COMPOSE_FILE="${FA_COMPOSE_FILE:-docker-compose.fa.yml}"
COMPOSE="docker compose -f $REPO_DIR/$COMPOSE_FILE"

# TTY detection: pass -T (disable TTY) when stdin is not a terminal
# (pipes, scripts, cron). Keep TTY for interactive use (fa shell).
TTY_FLAG="-T"
if [ -t 0 ] && [ -t 1 ]; then
    TTY_FLAG=""
fi

# Resolve active session workspace for docker exec commands
_SESSION_WORKSPACE=""
if [[ -f "$REPO_DIR/../../sessions/.active" ]]; then
    _SESSION_WORKSPACE="$(cat "$REPO_DIR/../../sessions/.active")"
fi

_W_FLAG=""
if [[ -n "$_SESSION_WORKSPACE" ]]; then
    _W_FLAG="-w $_SESSION_WORKSPACE"
fi

case "${1:-}" in
    # ── Infrastructure verbs (host-side, docker compose level) ──────────
    logs)
        shift
        exec $COMPOSE logs "$@" first-agent
        ;;
    proxy-logs)
        shift
        exec $COMPOSE logs "$@" fa-egress-proxy
        ;;
    status)
        exec $COMPOSE ps
        ;;
    up)
        exec $COMPOSE up -d
        ;;
    down)
        exec $COMPOSE down
        ;;
    restart)
        exec $COMPOSE restart first-agent fa-egress-proxy
        ;;
    rebuild)
        exec $COMPOSE up -d --build
        ;;
    shell)
        shift
        if [[ -n "$_W_FLAG" ]]; then
            exec $COMPOSE exec -w "$_SESSION_WORKSPACE" first-agent bash "$@"
        else
            exec $COMPOSE exec first-agent bash "$@"
        fi
        ;;
    update)
        shift
        exec "$REPO_DIR/scripts/fa-update.sh" "$@"
        ;;
    commit-traces)
        cd "$REPO_DIR"
        git add knowledge/trace/codebase_map.json knowledge/trace/gotchas.md 2>/dev/null
        git diff --cached --quiet && { echo "fa: no trace changes to commit"; exit 0; }
        git commit -m "chore: update session trace artifacts"
        echo "fa: trace artifacts committed"
        exit 0
        ;;

    sessions)
        ls -lt "$REPO_DIR/../../sessions/" | grep -v "^total\|\.active"
        ;;

    # ── Help ────────────────────────────────────────────────────────────
    ""|--help|-h|help)
        cat <<'EOF'
Usage: fa <command> [args...]

Infrastructure (host-side, docker compose):
  logs [flags]       Agent container logs       (e.g. fa logs -f --tail=50)
  proxy-logs [flags] Proxy container logs
  status             Show container status
  up                 Start containers
  down               Stop containers
  restart            Restart both containers
  rebuild            Rebuild images and restart
  shell              Open bash inside agent container
  update [flags]     Pull latest + rebuild (runs fa-update.sh)
  commit-traces      Commit session trace artifacts to git

Agent CLI (inside container):
  selfcheck          Validate config + proxy routing (free)
  probe              Liveness test — real API call (~10 tokens)
  run                Drive an LLM session
  stats              Session analytics (tool usage, tokens, efficiency)
  chunk              Run the deterministic chunker
  authoring-check    Run ADR-11 authoring guardrails
  --version          Show fa version

All unrecognised commands pass through to `fa` inside the container.
Add new Python subcommands in src/fa/cli.py — they work here automatically.
EOF
        exit 0
        ;;

    # ── Default: delegate to fa CLI inside the agent container ──────────
    *)
        if [[ -n "$_W_FLAG" ]]; then
            exec $COMPOSE exec $TTY_FLAG -w "$_SESSION_WORKSPACE" first-agent fa "$@"
        else
            exec $COMPOSE exec $TTY_FLAG first-agent fa "$@"
        fi
        ;;
esac
