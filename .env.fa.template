# First-Agent production environment variables
# Place this file in repo root as .env.fa (Docker Compose loads it automatically).
# NEVER commit .env.fa to git — it is already in .gitignore and .gitleaks.toml.
#
# Convention separation:
#   - LLM API keys         -> .env.fa (container runtime, loaded by compose)
#   - Backup credentials     -> /srv/first-agent/secrets/backup.env (host only)
#   - Git deploy key         -> /srv/first-agent/secrets/github_deploy_key (read-only mount)
#
# Uncomment and fill in the keys for the providers you actually use.
# See knowledge/examples/models.yaml.example for provider chain configuration.

# Primary providers (used by models.yaml.example)
# OPENROUTER_API_KEY=sk-or-v1-CHANGEME
# FIREWORKS_API_KEY=fw-CHANGEME

# Optional container auto-run controls. Default container mode is stand-by
# for manual `docker exec`. To run exactly one startup task, set
# FA_AUTO_RUN=1 and provide either FA_TASK or FA_TASK_FILE (not both).
# Prefer FA_TASK_FILE for long plan-following workflows; it must resolve
# inside /workspace.
# FA_AUTO_RUN=0
# FA_TASK=Implement the change described in /workspace/tasks/example.md
# FA_TASK_FILE=tasks/example.md
# FA_ROLE=coder
# FA_MAX_TURNS=16
# FA_RUN_ID=my-run-id
# FA_RESUME=0
# FA_CONFIG=/home/fa/.fa/models.yaml

# Additional providers (uncomment as needed)
# ANTHROPIC_API_KEY=sk-ant-CHANGEME
# OPENAI_API_KEY=sk-CHANGEME
# GROQ_API_KEY=gsk_CHANGEME
# TOGETHER_API_KEY=together-CHANGEME
# XAI_API_KEY=xai-CHANGEME
# CEREBRAS_API_KEY=csk-CHANGEME
# PERPLEXITY_API_KEY=pplx-CHANGEME
# NVIDIA_BUILD_API_KEY=nvapi-CHANGEME
# GITHUB_MODELS_API_KEY=ghp_CHANGEME
# MODAL_API_KEY=ak-CHANGEME
# LAMBDA_LABS_API_KEY=lambda-CHANGEME
