# First-Agent NON-SECRET runtime controls.
# Place this file in repo root as .env.fa (Docker Compose loads it automatically).
# NEVER commit .env.fa to git — it is already in .gitignore and .gitleaks.toml.
#
# Convention separation (ADR-12 secret isolation):
#   - LLM API keys         -> /srv/first-agent/secrets/fa.env  (consumed ONLY by
#                             the fa-egress-proxy container; the agent container
#                             never sees them). See secrets/fa.env.template.
#   - fa→proxy token       -> /srv/first-agent/secrets/fa_proxy_token (host only)
#   - Backup credentials   -> /srv/first-agent/secrets/backup.env (host only)
#   - Git deploy key       -> /srv/first-agent/secrets/github_deploy_key (ro mount)
#
# API KEYS DO NOT GO HERE. This file holds only non-secret FA_* controls.
# See knowledge/examples/models.yaml.example for provider chain configuration.

# Optional container auto-run controls. Default container mode is stand-by
# for manual `docker exec`. To run exactly one startup task, set
# FA_AUTO_RUN=1 and provide either FA_TASK or FA_TASK_FILE (not both).
# Prefer FA_TASK_FILE for long plan-following workflows; it must resolve
# inside /workspace.
# FA_AUTO_RUN=0
# FA_TASK=Implement the change described in /workspace/tasks/example.md
# FA_TASK_FILE=tasks/example.md
# FA_ROLE=coder
# FA_MAX_TURNS=16
# FA_RUN_ID=my-run-id
# FA_RESUME=0
# FA_CONFIG=/home/fa/.fa/models.yaml

# Point the agent at the egress proxy (set by docker-compose.fa.yml):
# FA_EGRESS_PROXY_URL=http://fa-egress-proxy:8080
#
# API keys are NOT configured here. They live in
# /srv/first-agent/secrets/fa.env (see secrets/fa.env.template) and are read
# ONLY by the fa-egress-proxy container.
