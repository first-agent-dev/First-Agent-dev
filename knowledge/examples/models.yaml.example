# First-Agent models.yaml — example template
#
# DEPLOY LOCATION (AIO / Docker): /srv/first-agent/routing/models.yaml
#   The host operator edits this ONE file; it is bind-mounted READ-ONLY into BOTH
#   the agent (as ~/.fa/models.yaml) and the egress proxy (as /etc/fa/models.yaml).
#   After editing it, recreate the proxy so it reloads the routes, e.g.:
#     scripts/fa-update.sh
#   (or: docker compose -f docker-compose.fa.yml up -d --force-recreate)
# LOCAL DEV (no Docker): ~/.fa/models.yaml
#
# This file is ROUTING ONLY: which model, at which URL, with which API-key NAME.
# It does NOT carry sampling parameters (temperature / top_p / top_k / max_tokens
# / penalties) yet — First-Agent sets those in the agent loop. Any extra key you
# add to a chain entry below is currently IGNORED by the loader (see BACKLOG
# I-25). Only these fields are read:
#   provider, slug, base_url, api_key_env  (required)
#   timeout_seconds, cooldown_seconds, transport_retries, extra_headers  (optional)
#     timeout_seconds: per-request HTTP timeout in seconds
#     cooldown_seconds: local cooldown floor after transient provider failure
#     transport_retries: extra transport-level retries for low-level network failures
#     extra_headers: additional HTTP headers for this route
#
# NEVER paste real API keys into this file. `api_key_env` is the NAME of the key;
# the real value lives ONLY in /srv/first-agent/secrets/fa.env (proxy-only):
#   FIREWORKS_API_KEY=fw-...
#
# Recognised roles: planner, coder, debug, eval. A single-role config is legal.
# ⚠️ eval-family rule (ADR-2 §Amendment 2026-05-20): if you declare planner AND
#    coder AND eval together, eval's `family:` MUST differ from BOTH planner's and
#    coder's, or the config REFUSES TO LOAD (EvalFamilyConflictError). planner and
#    coder MAY share a family; only eval must be disjoint from the two actors.

# ───────────────────────────────────────────────────────────────────────────
# Default three-role setup (all on Fireworks; OpenAI-compatible adapter).
# planner = GLM 5.2, coder = MiniMax M3, eval = Nemotron 3 Ultra.
# Families glm / minimax / nemotron are all distinct → ADR-2 eval-disjoint holds.
# (eval canNOT also be glm-5p2: that family would collide with the planner and
#  the config would be rejected — hence Nemotron for the evaluator.)
# All three support Function Calling (required by the agent's tool-call loop).
# ───────────────────────────────────────────────────────────────────────────

planner:
  model: "glm-5p2"
  family: "glm"            # free-text label; authoritative for the eval-disjoint check
  chain:
    - provider: fireworks
      slug: "accounts/fireworks/models/glm-5p2"
      base_url: "https://api.fireworks.ai/inference/v1"
      api_key_env: FIREWORKS_API_KEY
      timeout_seconds: 15
      cooldown_seconds: 3
      transport_retries: 1

coder:
  model: "minimax-m3"
  family: "minimax"
  chain:
    - provider: fireworks
      slug: "accounts/fireworks/models/minimax-m3"
      base_url: "https://api.fireworks.ai/inference/v1"
      api_key_env: FIREWORKS_API_KEY
      timeout_seconds: 15
      cooldown_seconds: 3
      transport_retries: 1

eval:
  model: "nemotron-3-ultra-nvfp4"
  family: "nemotron"       # distinct from glm + minimax → ADR-2 disjoint OK
  chain:
    - provider: fireworks
      slug: "accounts/fireworks/models/nemotron-3-ultra-nvfp4"
      base_url: "https://api.fireworks.ai/inference/v1"
      api_key_env: FIREWORKS_API_KEY
      timeout_seconds: 15
      cooldown_seconds: 3
      transport_retries: 1

# ───────────────────────────────────────────────────────────────────────────
# Notes
# ───────────────────────────────────────────────────────────────────────────
# - Single model for ALL roles (quick testing): declare ONLY the roles you call
#   (e.g. just `coder`), OR omit `eval` — declaring planner+coder+eval as the
#   SAME family is rejected by the ADR-2 disjoint rule.
# - A chain CAN have multiple entries; the agent tries them top-to-bottom on
#   failure (provider fallback). Example for one role:
#     chain:
#       - provider: fireworks
#         slug: "accounts/fireworks/models/minimax-m3"
#         base_url: "https://api.fireworks.ai/inference/v1"
#         api_key_env: FIREWORKS_API_KEY
#       - provider: openrouter
#         slug: "minimax/minimax-m3"
#         base_url: "https://openrouter.ai/api/v1"
#         api_key_env: OPENROUTER_API_KEY
