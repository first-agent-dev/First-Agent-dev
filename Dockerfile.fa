# Dockerfile for First-Agent runtime container
# Ubuntu 24.04 base with uv, just (from apt), and Python 3.13

FROM ubuntu:24.04

# Prevent interactive prompts during build
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV UV_CACHE_DIR=/tmp/uv-cache
ENV PATH=/opt/fa-venv/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

# Make curl/installer pipelines fail as a unit, and make apt downloads less
# brittle on headless rebuilds where transient mirror/network failures are common.
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN printf '%s\n' \
    'Acquire::Retries "5";' \
    'Acquire::http::Timeout "30";' \
    'Acquire::https::Timeout "30";' \
    > /etc/apt/apt.conf.d/80-retries

# Install system dependencies. `just` is intentionally installed from Ubuntu's
# apt package instead of the dynamic just.systems/GitHub Releases installer: the
# runtime image keeps the dependency, but clean AIO rebuilds no longer depend on
# a second, fragile release-download path.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    git \
    just \
    openssh-client \
    universal-ctags \
    && just --version \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user matching host UID (1000).
# Ubuntu 24.04 cloud images may include a default user at UID 1000;
# remove it first so we can create 'fa' with the same UID.
RUN if id -u 1000 >/dev/null 2>&1; then \
        existing=$(id -un 1000); \
        userdel -r "$existing" 2>/dev/null || true; \
    fi && \
    useradd -m -u 1000 -s /bin/bash fa && \
    mkdir -p /home/fa/.ssh && \
    chmod 700 /home/fa/.ssh

# Install uv (Astral package manager) straight into /usr/local/bin. Use the
# installer's own UV_INSTALL_DIR so it never depends on $HOME (which differs
# between the build-time root user and the runtime fa user) — the previous
# `mv /root/.local/bin/...` broke as soon as HOME was pinned.
RUN curl --fail --location --show-error --silent \
        --retry 5 --retry-all-errors --connect-timeout 15 --max-time 180 \
        -o /tmp/uv-install.sh https://astral.sh/uv/install.sh \
    && env UV_INSTALL_DIR=/usr/local/bin INSTALLER_NO_MODIFY_PATH=1 sh /tmp/uv-install.sh \
    && rm -f /tmp/uv-install.sh \
    && chmod +x /usr/local/bin/uv /usr/local/bin/uvx \
    && uv --version

# Install Python 3.13 into a WORLD-READABLE shared location (not /root/.local,
# which is mode 700 and unreadable by the non-root 'fa' user at runtime — that
# caused `bad interpreter: Permission denied` when the venv's python3 symlink
# pointed into root's home). UV_PYTHON_INSTALL_DIR puts it under /opt so any uid
# can traverse + execute it.
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
RUN mkdir -p /opt/uv-python && \
    uv python install 3.13 && \
    PYTHON_BIN=$(uv python find 3.13) && \
    [ -n "$PYTHON_BIN" ] && \
    ln -sf "$PYTHON_BIN" /usr/local/bin/python3.13 && \
    ln -sf python3.13 /usr/local/bin/python3 && \
    ln -sf python3.13 /usr/local/bin/python && \
    chmod -R a+rX /opt/uv-python /usr/local/bin/python3.13

# Install FA runtime dependencies into an image-owned venv. The live
# bind-mounted /workspace/src still wins at runtime via PYTHONPATH, so
# normal source edits do not require an image rebuild; dependency changes do.
COPY pyproject.toml uv.lock README.md /opt/first-agent/
COPY src /opt/first-agent/src
# After building the image-owned venv, make it world-readable/executable so the
# non-root 'fa' user can run /opt/fa-venv/bin/python3 at runtime (defends against
# any root-only default perms).
RUN cd /opt/first-agent && \
    uv venv /opt/fa-venv --python /usr/local/bin/python3.13 && \
    UV_PROJECT_ENVIRONMENT=/opt/fa-venv uv sync --frozen --no-dev && \
    rm -rf /tmp/uv-cache && \
    chmod -R a+rX /opt/fa-venv /opt/first-agent

# Container entrypoint: command override, explicit one-shot auto-run,
# or default inspectable stand-by mode.
COPY --chmod=755 scripts/fa-entrypoint.sh /usr/local/bin/fa-entrypoint.sh

# Create /run/secrets for deploy key + known_hosts bind-mounts
RUN mkdir -p /run/secrets && chmod 755 /run/secrets

# Set up working directories
RUN mkdir -p /workspace /config \
    && chown -R fa:fa /workspace /config /home/fa /run/secrets

RUN mkdir -p /repo /sessions \
    && chown fa:fa /sessions
# Keep WORKDIR /workspace for backward compatibility during transition,
# but the entrypoint will cd to the session dir.

# SSH client is installed above; Git auth is configured via GIT_SSH_COMMAND env var
# in docker-compose.fa.yml (points to /run/secrets/git_key + known_hosts)

# Authoritative HOME for the RUNTIME user. Set AFTER all root build steps so it
# does not perturb build-time tools that key off $HOME (the uv installer did).
# docker-compose runs the container as numeric `user: "1000:1000"`, for which
# Docker does not reliably derive HOME from /etc/passwd (it can default to "/");
# the agent uses Path.home() for state (~/.fa/...), so pin it to the fa home.
ENV HOME=/home/fa

USER fa
WORKDIR /workspace

# Default: entrypoint enters stand-by mode. Passing a docker command
# override (e.g. `bash`) execs that command instead.
ENTRYPOINT ["/usr/local/bin/fa-entrypoint.sh"]
